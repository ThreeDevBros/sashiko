<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <!-- Required by Google Pay (via @capacitor-community/stripe) -->
        <meta-data
            android:name="com.google.android.gms.wallet.api.enabled"
            android:value="true" />

        <!-- Enables Google Pay inside the @capacitor-community/stripe plugin.
             When this is true, the plugin reads `publishable_key` below at native
             load time and configures the GooglePayLauncher. If the key is missing,
             Google Pay silently fails to initialize. -->
        <meta-data
            android:name="com.getcapacitor.community.stripe.enable_google_pay"
            android:value="true" />

        <!-- Stripe publishable key (TEST). Replace with your LIVE key for production builds.
             This is required by the Stripe Capacitor plugin to bring up Google Pay on Android. -->
        <meta-data
            android:name="com.getcapacitor.community.stripe.publishable_key"
            android:value="pk_live_51LxuXZIsawC8FwOEkXg1tJ6Gsu3m655FgHU7cQ0SujDwBBZSRmpJ7kDHwQftuDUXOVPc6NvhuejgByE7D2ONLvYf00vGVuREwg" />

        <!-- Google Pay PRODUCTION environment. Must be false when using a Stripe
             LIVE publishable key, otherwise isGooglePayAvailable() rejects and the
             Google Pay button is silently hidden. The release APK must be signed with
             the upload cert registered in the Google Pay & Wallet Console. -->
        <meta-data
            android:name="com.getcapacitor.community.stripe.google_pay_is_testing"
            android:value="false" />

        <!-- Merchant display name shown inside the Google Pay sheet -->
        <meta-data
            android:name="com.getcapacitor.community.stripe.merchant_display_name"
            android:value="Sashiko Asian Fusion" />

        <!-- Default country (ISO-3166-1 alpha-2) -->
        <meta-data
            android:name="com.getcapacitor.community.stripe.country_code"
            android:value="GR" />

        <!-- Google Pay sheet defaults — keep all collection off so the sheet stays light -->
        <meta-data
            android:name="com.getcapacitor.community.stripe.email_address_required"
            android:value="false" />
        <meta-data
            android:name="com.getcapacitor.community.stripe.phone_number_required"
            android:value="false" />
        <meta-data
            android:name="com.getcapacitor.community.stripe.billing_address_required"
            android:value="false" />
        <meta-data
            android:name="com.getcapacitor.community.stripe.billing_address_format"
            android:value="Min" />
        <meta-data
            android:name="com.getcapacitor.community.stripe.google_pay_existing_payment_method_required"
            android:value="false" />

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- OAuth callback (Apple/Google web flow) — App Link to production domain -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https"
                      android:host="sashikoasianfusion.com"
                      android:pathPrefix="/~oauth" />
            </intent-filter>

            <!-- Custom scheme deep link (fallback for OAuth redirects) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="com.sashiko.app" android:host="auth" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Geolocation (Capacitor Geolocation plugin) -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-feature android:name="android.hardware.location.gps" android:required="false" />

    <!-- Network state (used by some plugins) -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
</manifest>
